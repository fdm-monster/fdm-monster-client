{
  "name": "@fdm-monster/client",
  "version": "1.0.0-alpha",
  "scripts": {
    "serve": "vite preview",
    "build": "vite build",
    "test:unit": "vitest --environment jsdom",
    "test:coverage": "vitest run --coverage --environment jsdom",
    "test:e2e": "start-server-and-test preview http://127.0.0.1:5050/ 'cypress open'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "dev": "vite",
    "prettier": "prettier --write **/*.ts",
    "preview": "vite preview --port 5050",
    "test:e2e:ci": "start-server-and-test preview http://127.0.0.1:5050/ 'cypress run'",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "dependencies": {
    "@formvuelate/plugin-vee-validate": "^3.8.1",
    "@vee-validate/rules": "4.5.11",
    "@vee-validate/zod": "^4.5.11",
    "@vueuse/core": "8.4.2",
    "@vueuse/integrations": "8.4.2",
    "axios": "0.27.2",
    "event-source-polyfill": "^1.0.26",
    "formvuelate": "^3.8.1",
    "luxon": "2.3.2",
    "pinia": "2.0.14",
    "roboto-fontface": "*",
    "validator": "^13.7.0",
    "vee-validate": "4.5.11",
    "vue": "3.2.33",
    "vue-axios": "^3.4.1",
    "vue-router": "4.0.15",
    "vuedraggable": "^4.1.0",
    "vuetify": "3.0.0-beta.1",
    "webfontloader": "^1.6.28",
    "zod": "3.15.1"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.1.3",
    "@types/event-source-polyfill": "^1.0.0",
    "@types/jsdom": "16.2.14",
    "@types/luxon": "2.3.2",
    "@types/node": "17.0.29",
    "@types/validator": "^13.7.2",
    "@types/webfontloader": "^1.6.34",
    "@vitejs/plugin-vue": "2.3.2",
    "@vitejs/plugin-vue-jsx": "1.3.10",
    "@vue/eslint-config-prettier": "7.0.0",
    "@vue/eslint-config-typescript": "10.0.0",
    "@vue/test-utils": "2.0.0-rc.21",
    "@vue/tsconfig": "0.1.3",
    "@vuetify/vite-plugin": "^1.0.0-alpha.10",
    "c8": "^7.11.2",
    "cypress": "9.6.0",
    "eslint": "8.14.0",
    "eslint-plugin-cypress": "2.12.1",
    "eslint-plugin-vue": "8.7.1",
    "jsdom": "19.0.0",
    "material-design-icons-iconfont": "6.7.0",
    "prettier": "2.6.2",
    "sass": "1.51.0",
    "sass-loader": "^12.6.0",
    "start-server-and-test": "1.14.0",
    "typescript": "4.6.4",
    "unplugin-auto-import": "^0.7.1",
    "unplugin-vue-components": "^0.19.3",
    "vite": "2.9.8",
    "vitest": "0.10.5",
    "vue-cli-plugin-vuetify": "~2.4.8",
    "vue-tsc": "0.34.11",
    "vuetify-loader": "^2.0.0-alpha.9"
  }
}
