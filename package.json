    "roboto-fontface": "*",
    "validator": "^13.7.0",
    "vee-validate": "^4.5.10",
    "vue": "3.2.31",
    "vue-axios": "^3.4.1",
    "vue-router": "4.0.14",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.0.0-beta.0",
    "webfontloader": "^1.6.28",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.1.2",
    "@types/jsdom": "16.2.14",
    "@types/luxon": "^2.3.1",
    "@types/node": "17.0.23",
    "@types/validator": "^13.7.2",
    "@types/webfontloader": "^1.6.34",
    "@vitejs/plugin-vue": "2.3.1",
    "@vitejs/plugin-vue-jsx": "1.3.9",
    "@vue/eslint-config-prettier": "7.0.0",
    "@vue/eslint-config-typescript": "10.0.0",
    "@vue/test-utils": "2.0.0-rc.19",
    "@vue/tsconfig": "0.1.3",
    "@vuetify/vite-plugin": "^1.0.0-alpha.10",
    "cypress": "9.5.3",
    "eslint": "8.12.0",
    "eslint-plugin-cypress": "2.12.1",
    "eslint-plugin-vue": "8.6.0",
    "jsdom": "19.0.0",
    "material-design-icons-iconfont": "^6.5.0",
    "prettier": "2.6.2",
    "sass": "^1.49.11",
    "sass-loader": "^12.6.0",
